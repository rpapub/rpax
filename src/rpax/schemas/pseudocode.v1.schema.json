{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rpax.dev/schemas/pseudocode.v1.schema.json",
  "title": "rpax pseudocode artifact",
  "description": "Schema for pseudocode/*.json artifacts generated by rpax parse",
  "type": "object",
  "required": [
    "workflowId",
    "projectId",
    "projectSlug",
    "schemaVersion",
    "generatedAt",
    "rpaxVersion",
    "activities",
    "activityCount"
  ],
  "properties": {
    "workflowId": {
      "type": "string",
      "description": "Extension-free relative path used as workflow identifier (e.g. Framework/CheckExists)"
    },
    "projectId": {
      "type": "string",
      "description": "Project identifier"
    },
    "projectSlug": {
      "type": "string",
      "description": "URL-safe project slug"
    },
    "relativePath": {
      "type": "string",
      "description": "Source XAML path relative to project root (e.g. Framework/CheckExists.xaml)"
    },
    "schemaVersion": {
      "type": "string",
      "description": "Artifact schema version"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 generation timestamp"
    },
    "rpaxVersion": {
      "type": "string",
      "description": "rpax version that generated this artifact"
    },
    "activities": {
      "type": "array",
      "description": "Pseudocode entries for each visual activity",
      "items": {
        "$ref": "#/$defs/pseudocodeEntry"
      }
    },
    "activityCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of visual activities"
    },
    "formatVersion": {
      "type": "string",
      "description": "Pseudocode format variant (default: gist-style)"
    },
    "totalLines": {
      "type": "integer",
      "minimum": 0
    },
    "totalActivities": {
      "type": "integer",
      "minimum": 0
    },
    "entries": {
      "type": "array",
      "description": "Legacy pseudocode entries (same as activities)",
      "items": {
        "$ref": "#/$defs/pseudocodeEntry"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional generation metadata"
    },
    "generationConfig": {
      "type": "object",
      "description": "Configuration used during generation"
    }
  },
  "$defs": {
    "pseudocodeEntry": {
      "type": "object",
      "required": ["indent", "displayName", "tag", "activityPath", "formattedLine", "nodeId", "depth", "isVisual"],
      "properties": {
        "indent": {
          "type": "integer",
          "minimum": 0,
          "description": "Indentation level"
        },
        "displayName": {
          "type": "string",
          "description": "Activity DisplayName attribute"
        },
        "tag": {
          "type": "string",
          "description": "Activity XML local tag name"
        },
        "activityPath": {
          "type": "string",
          "description": "XML traversal path within the workflow (e.g. Activity/Sequence/If)"
        },
        "formattedLine": {
          "type": "string",
          "description": "Gist-style pseudocode line"
        },
        "nodeId": {
          "type": "string",
          "description": "Stable node identifier"
        },
        "depth": {
          "type": "integer",
          "minimum": 0,
          "description": "Nesting depth in activity tree"
        },
        "isVisual": {
          "type": "boolean",
          "description": "True if the activity is visible in the workflow designer"
        },
        "children": {
          "type": "array",
          "description": "Nested child pseudocode entries",
          "items": {
            "$ref": "#/$defs/pseudocodeEntry"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
